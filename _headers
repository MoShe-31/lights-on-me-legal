# Force HTML revalidation so each deploy is served fresh (no manual cache purge).
# Images, icons and other static assets keep their normal caching.
/fr
  Cache-Control: no-cache

/en
  Cache-Control: no-cache

/de
  Cache-Control: no-cache

/it
  Cache-Control: no-cache

/es
  Cache-Control: no-cache

/pt
  Cache-Control: no-cache

/*.html
  Cache-Control: no-cache
